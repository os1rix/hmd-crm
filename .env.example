# Database (host port 5433 — 5432 is often taken by a local Postgres install)
DATABASE_URL=postgresql://hmd:hmd@localhost:5433/hmd_crm

# App
NODE_ENV=development
NEXT_PUBLIC_APP_URL=http://localhost:3000

# Optional: ngrok origin for dev HMR (e.g. https://your-subdomain.ngrok-free.dev)
# ALLOWED_DEV_ORIGINS=

# Azure Entra ID (configure before Azure deployment)
# AZURE_AD_CLIENT_ID=
# AZURE_AD_CLIENT_SECRET=
# AZURE_AD_TENANT_ID=

# Azure OpenAI (for AI agents)
# AZURE_OPENAI_ENDPOINT=
# AZURE_OPENAI_API_KEY=
# AZURE_OPENAI_DEPLOYMENT=
